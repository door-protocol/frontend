# Keeper Bot Configuration

# Private key of the keeper wallet (must have KEEPER_ROLE)
# IMPORTANT: Never commit this file with real private keys!
# For production, use GitHub Secrets instead
KEEPER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# RPC URL for Mantle Sepolia
RPC_URL=https://rpc.sepolia.mantle.xyz

# Contract addresses (Mantle Sepolia)
EPOCH_MANAGER_ADDRESS=0xdc0f912aa970f2a89381985a8e0ea3128e754748

# Check interval in seconds (default: 5 minutes)
CHECK_INTERVAL=300

# Enable dry run mode (no actual transactions)
# Set to true for testing, false for production
DRY_RUN=true
